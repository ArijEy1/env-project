PORT=4000
CORS_ORIGIN=http://localhost:3000

# Set when running behind a reverse proxy / load balancer so client IPs
# (used for rate limiting) are read correctly. Use the number of trusted
# proxy hops (e.g. 1) or "true". Leave unset for direct/local access.
TRUST_PROXY=

# REQUIRED. Must be a strong random value of >= 32 chars. The app refuses to start otherwise.
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
# 8-hour sessions; the web app silently refreshes the token while the user is active.
JWT_EXPIRES_IN=8h

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
# Use a strong password in any non-local environment.
POSTGRES_PASSWORD=postgres
POSTGRES_DB=env_project
POSTGRES_ADMIN_DB=postgres
# Set to true and use a CA-verified connection for managed/production databases.
POSTGRES_SSL=false

APP_WEB_URL=http://localhost:3000
PASSWORD_RESET_TTL_MINUTES=30

# Draft assessment lifecycle (hourly job): email a reminder after this many days
# of inactivity, and delete the draft after the retention window.
DRAFT_REMINDER_DAYS=3
DRAFT_RETENTION_DAYS=30

# Set to true in production to force HTTP->HTTPS redirects (requires TRUST_PROXY
# when behind a load balancer). HSTS is always sent via Helmet.
FORCE_HTTPS=false

# SMTP — leave SMTP_HOST blank to log reset links to the console in development.
# Never commit real credentials; inject these via your deployment secrets manager.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@env-project.local
